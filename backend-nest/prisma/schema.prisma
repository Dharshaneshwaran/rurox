generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum Day {
  MON
  TUE
  WED
  THU
  FRI
}

enum SubstitutionStatus {
  PENDING
  ACCEPTED
  REJECTED
  REASSIGNED
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(TEACHER)
  approved  Boolean  @default(false)
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  teacherId String?  @unique
  student   Student? @relation(fields: [studentId], references: [id])
  studentId String?  @unique
  createdAt DateTime @default(now())
}

model Teacher {
  id                       String         @id @default(cuid())
  name                     String
  subjects                 String[]       @default([])
  user                     User?
  timetables               Timetable[]
  specialClasses           SpecialClass[]
  substitutionsAsReplacement Substitution[] @relation("replacement")
  substitutionsAsAbsent    Substitution[] @relation("absent")
  students                 Student[]      @relation("StudentTeacher")
  workload                 Int            @default(0)
}

model Student {
  id                  String   @id @default(cuid())
  name                String
  rollNumber          String   @unique
  className           String
  user                User?
  teachers            Teacher[] @relation("StudentTeacher")
  studentTimetables   StudentTimetable[]
  createdAt           DateTime @default(now())
}

model Timetable {
  id        String   @id @default(cuid())
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  teacherId String
  day       Day
  period    Int
  subject   String
  className String
  room      String?
  createdAt DateTime @default(now())

  @@unique([teacherId, day, period])
  @@index([day, period])
}

model StudentTimetable {
  id        String   @id @default(cuid())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  day       Day
  period    Int
  subject   String
  className String
  teacher   String?
  room      String?
  createdAt DateTime @default(now())

  @@unique([studentId, day, period])
  @@index([studentId, day, period])
}

model Substitution {
  id                   String   @id @default(cuid())
  absentTeacher        Teacher  @relation("absent", fields: [absentTeacherId], references: [id])
  absentTeacherId      String
  replacementTeacher   Teacher? @relation("replacement", fields: [replacementTeacherId], references: [id])
  replacementTeacherId String?
  day                  Day
  period               Int?
  date                 DateTime
  autoAssigned         Boolean  @default(false)
  status               SubstitutionStatus @default(PENDING)
  specialClass         SpecialClass? @relation(fields: [specialClassId], references: [id])
  specialClassId       String?       @unique
  createdAt            DateTime @default(now())

  @@index([day, period])
}

model SpecialClass {
  id        String   @id @default(cuid())
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  teacherId String
  date      DateTime
  fromTime  String
  toTime    String
  subject   String
  className String
  notes     String?
  createdAt DateTime @default(now())
  substitution Substitution?
}
